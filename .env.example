# Create a Slack app at https://api.slack.com/apps
# Enable: Slash Commands (/sql), Interactivity, OAuth (bot token)

SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret

# Local dev only (Socket Mode). Do NOT set on Render when using HTTP URLs.
# SLACK_APP_TOKEN=xapp-...

# Optional: host/port for local dev (default 3000)
PORT=3000
